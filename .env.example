# =============================================
# Z-API (WhatsApp - número próprio do studio)
# =============================================
ZAPI_INSTANCE_ID=xxxxxxxxxxxxxxxxxxxxxxxx
ZAPI_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ZAPI_CLIENT_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =============================================
# CONFIGURAÇÕES TWILIO (manter para fallback/testes)
# =============================================
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Número do dono do studio (para relatórios do Supervisor)
DONO_WHATSAPP=whatsapp:+5511999999999

# =============================================
# GOOGLE APIs (Service Account)
# =============================================
# Caminho para o arquivo JSON da conta de serviço
GOOGLE_SERVICE_ACCOUNT_KEY=./credentials/google-service-account.json

# IDs das planilhas Google Sheets
GOOGLE_SHEETS_CLIENTES_ID=1xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_SHEETS_FINANCEIRO_ID=1xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_SHEETS_OPERACIONAL_ID=1xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_SHEETS_MARKETING_ID=1xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_SHEETS_LOGS_ID=1xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID do Google Calendar
GOOGLE_CALENDAR_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@group.calendar.google.com

# =============================================
# SERVIDOR
# =============================================
PORT=3000
NODE_ENV=production

# URL base do webhook (após deploy)
BASE_URL=https://seu-app.vercel.app

# =============================================
# CONFIGURAÇÕES DO STUDIO
# =============================================
STUDIO_NAME=Voll Pilates Studio
STUDIO_ADDRESS=Av. Rubens Montanaro de Borba, 180B
